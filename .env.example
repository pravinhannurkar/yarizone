# ==================== SERVER ENVIRONMENT VARIABLES ====================
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=production
PORT=10000

# CORS - Your frontend URL (NO trailing slash)
CLIENT_URL=https://your-frontend-url.vercel.app

# MongoDB Atlas Connection String
# Get yours at: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/yarizone?retryWrites=true&w=majority

# JWT Secrets (generate random 32+ character strings)
JWT_SECRET=your-super-secret-jwt-key-change-this
REFRESH_TOKEN_SECRET=your-different-refresh-secret-key-change-this

# Cloudinary (for image uploads)
# Get yours at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

